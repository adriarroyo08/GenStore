SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
API_PORT=3002
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend (prefix with VITE_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal (Phase 2b — optional)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox
# VITE_PAYPAL_CLIENT_ID=

# Email (Resend)
# RESEND_API_KEY=re_...
# EMAIL_FROM=GenStore <pedidos@genstore.com>
# STOCK_ALERT_ADMIN_EMAIL=admin@genstore.com
# STOCK_ALERT_CRON_SECRET=random-secret

# Business info (invoices)
# BUSINESS_NAME=GenStore S.L.
# BUSINESS_NIF=B12345678
# BUSINESS_ADDRESS=Calle Ejemplo 1, 28001 Madrid
# BUSINESS_EMAIL=info@genstore.com
# BUSINESS_PHONE=+34 612 345 678

# SEUR (optional)
# SEUR_USER=
# SEUR_PASSWORD=
# SEUR_CONTRACT=
# SEUR_API_URL=

# Correos Express (optional)
# CORREOS_EXPRESS_USER=
# CORREOS_EXPRESS_PASSWORD=
# CORREOS_EXPRESS_CLIENT_CODE=

# MRW (optional)
# MRW_USER=
# MRW_PASSWORD=
# MRW_FRANCHISE_CODE=
# MRW_API_URL=

# Cron secrets
# SHIPPING_SYNC_CRON_SECRET=random-secret
